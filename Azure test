def analyze_cmi_with_rag(patient_symptoms, retrieved_diagnoses):
    """
    使用RAG結果進行CMI優化分析
    
    Args:
        patient_symptoms: 病人症狀描述字串
        retrieved_diagnoses: 從向量庫檢索到的診斷列表
    """
    
    # 1. 建立Prompt
    prompt = create_cmi_optimization_prompt(patient_symptoms, retrieved_diagnoses)
    
    # 2. 設定對話歷史（系統角色設定）
    messages = [
        {
            "role": "system",
            "content": "你是一位經驗豐富的醫療編碼專家，專精於DRG編碼與CMI優化。"
                       "你的回答必須專業、精確，且基於臨床證據。"
                       "特別注重高RW值診斷的識別與編碼完整性。"
        },
        {
            "role": "user",
            "content": prompt
        }
    ]
    
    # 3. 呼叫GPT-4o
    response = client.chat.completions.create(
        model=deployment,
        messages=messages,
        temperature=0.2,  # 降低隨機性，增加一致性
        max_tokens=2000   # 確保完整輸出
    )
    
    return response.choices[0].message.content

