from openai import AzureOpenAI

# 你的設定
client = AzureOpenAI(
    api_key='your-api-key',
    azure_endpoint='your-endpoint',
    api_version='2024-12-01-preview'
)

# 病例摘要
case = """
81歲女性，左腿腫脹一個月。
D-dimer 27.02（極高），CT顯示肺栓塞+多處深層靜脈血栓。
血小板減少(93,000)，CEA升高(5.4)。
有甲狀腺結節1.1cm、腎上腺結節1.2cm。
有帕金森氏症、高血脂症病史。
現有診斷碼：I2693, I82402, E785, G20
"""

# 直接問診斷建議
prompt = f"""
你是資深主治醫師。請針對以下病例，直接給出診斷建議：

【病例】
{case}

請：
1. 列出推薦的診斷碼（ICD-10格式）
2. 每項下面簡述原因（20字內）

格式：
1. ICD-10碼 - 診斷名稱
   原因：...
"""

response = client.chat.completions.create(
    model="gpt-4o",
    messages=[{"role": "user", "content": prompt}],
    temperature=0.2,
    max_tokens=800
)

print(response.choices[0].message.content)
