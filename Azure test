                print(f"  ❌ {point} (可能遺漏)")
        
        # 5. 儲存結果
        timestamp = "test_result"
        filename = f"diagnostic_analysis_{timestamp}.txt"
        
        with open(filename, "w", encoding="utf-8") as f:
            f.write("="*60 + "\n")
            f.write("診斷完整性分析報告\n")
            f.write("="*60 + "\n\n")
            f.write("【病例資料】\n")
            f.write(case_study + "\n\n")
            f.write("【GPT分析結果】\n")
            f.write(gpt_response + "\n\n")
            f.write("【質量評估】\n")
            f.write(f"總分: {evaluation['total_score']}/10\n")
            f.write(f"段落完整性: {evaluation['section_coverage']}\n")
            for item in evaluation["feedback"]:
                f.write(f"{item}\n")
        
        print(f"\n💾 結果已儲存至: {filename}")
        
        return {
            "response": gpt_response,
            "evaluation": evaluation,
            "filename": filename
        }
        
    except Exception as e:
        print(f"❌ 發生錯誤：{e}")
        return None

