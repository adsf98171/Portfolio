def create_diagnostic_prompt(case_text, evaluation_focus="completeness"):
    """
    建立診斷完整性分析Prompt（無RW值版本）
    
    evaluation_focus選項：
    - "completeness": 診斷完整性
    - "precision": ICD-10精確度  
    - "clinical": 臨床合理性
    - "all": 全面分析
    """
    
    focus_instructions = {
        "completeness": """
        請專注分析「診斷完整性」：
        1. 現有診斷是否足夠反映疾病全貌？
        2. 哪些重要診斷可能被遺漏？
        3. 根據檢查結果，應考慮哪些額外診斷？
        """,
        
        "precision": """
        請專注分析「ICD-10精確度」：
        1. 現有代碼是否使用最精確的子代碼？
        2. 是否有更準確的代碼可用？
        3. 代碼選擇是否符合臨床表現？
        """,
        
        "clinical": """
        請專注分析「臨床合理性」：
        1. 診斷組合是否符合臨床邏輯？
        2. 是否有矛盾或不一致的診斷？
        3. 是否需要進一步檢查確認？
        """,
        
        "all": """
        請進行全面分析，包含：
        1. 診斷完整性審查
        2. ICD-10代碼精確度評估
        3. 臨床合理性檢查
        4. 具體改進建議
        """
    }
    
    prompt = f"""
# 角色設定
你是一位資深臨床醫師兼醫療編碼顧問，擁有15年臨床經驗。
你的專長是：從複雜臨床資料中識別完整診斷組合，確保病歷反映真實疾病負擔。

# 分析任務
{focus_instructions.get(evaluation_focus, focus_instructions['all'])}

# 病例資料
{case_text}

# 輸出格式要求

## 📋 現有診斷評估
（對每個現有診斷碼進行評價）

## 🔍 可能遺漏的診斷
（基於檢查發現，列出應考慮但未列出的診斷）

## 🎯 ICD-10代碼精確化建議
（如有更精確的代碼）

## ⚠️ 臨床疑慮與建議
（需要澄清或進一步檢查的事項）

## 📊 診斷完整性評分
請給分（1-10分，10分最完整）：
- 完整性分數：__/10
- 精確度分數：__/10  
- 臨床合理性分數：__/10

# 重要原則
1. **循證醫學**：每個建議必須有病例中的證據支持
2. **臨床實用**：建議應實際可行，非純理論
3. **分級思考**：區分主要問題、併發症、共病
4. **務實優先**：優先考慮對治療有影響的診斷

請開始分析：
"""
    return prompt

def evaluate_gpt_response(response_text, case_text):
    """
    評估GPT回答質量的簡單函數
    返回評估報告
    """
    
    evaluation_criteria = {
        "completeness": {
            "description": "是否識別出可能遺漏的診斷",
            "keywords": ["遺漏", "未列出", "應考慮", "可能", "建議增加"]
        },
        "specificity": {
            "description": "是否提供具體的ICD-10建議",
            "keywords": ["I26.", "I82.", "E78.", "G20", "ICD-10", "代碼"]
        },
        "clinical_reasoning": {
            "description": "是否提供臨床推理過程",
            "keywords": ["因為", "由於", "基於", "證據", "檢查顯示"]
        },
        "actionability": {
            "description": "建議是否具體可行",
            "keywords": ["進一步檢查", "建議", "應", "需要", "確認"]
        }
    }
    
    # 簡單關鍵詞匹配評估
    scores = {}
    feedback = []
    
    for criterion, info in evaluation_criteria.items():
        keyword_count = 0
        for keyword in info["keywords"]:
            if keyword.lower() in response_text.lower():
                keyword_count += 1
        
        # 計算分數（0-3分）
        score = min(keyword_count, 3)
        scores[criterion] = score
        
        feedback.append(f"{criterion}: {score}/3 - {info['description']}")
    
    # 計算總分
    total_score = sum(scores.values()) / len(scores) * 10  # 轉為10分制
    
    # 檢查是否有評分
    has_scoring = "分數" in response_text or "評分" in response_text or "/10" in response_text
    
    # 檢查結構完整性
    sections = ["現有診斷", "遺漏", "ICD-10", "臨床", "建議"]
    section_coverage = sum(1 for section in sections if section in response_text)
    
    return {
        "total_score": round(total_score, 1),
        "detailed_scores": scores,
        "feedback": feedback,
        "has_scoring": has_scoring,
        "section_coverage": f"{section_coverage}/{len(sections)}",
        "response_length": len(response_text)
    }

def run_diagnostic_analysis():
    """執行完整的診斷分析與評估"""
    
    print("🔬 開始診斷完整性分析...")
    print("=" * 70)
    
    # 1. 發送請求
    prompt = create_diagnostic_prompt(case_study, "all")
    
    try:
        response = client.chat.completions.create(
            model="gpt-4o",
            messages=[
                {"role": "system", "content": "你是嚴謹的臨床診斷專家，回答要基於證據。"},
