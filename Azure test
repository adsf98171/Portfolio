print("🤖 AI醫療編碼專家分析中，請稍候...\n")
print("=" * 70)

try:
    response = client.chat.completions.create(
        model=deployment,
        messages=[
            {
                "role": "system", 
                "content": "你是一位有20年經驗的醫療編碼專家，專精於DRG、ICD-10編碼與CMI優化。請用專業但易懂的中文回答。"
            },
            {
                "role": "user",
                "content": cmi_prompt
            }
        ],
        temperature=0.3,  # 降低隨機性，確保專業性
        max_tokens=4000,  # 確保完整分析
        top_p=0.9
    )
    
    # 輸出結果
    result = response.choices[0].message.content
    print(result)
    
    # 儲存結果到檔案
    with open("single_case_cmi_analysis.txt", "w", encoding="utf-8") as f:
        f.write("# 病例CMI優化分析報告\n")
