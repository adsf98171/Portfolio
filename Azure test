            "2. 血小板減少可能指向其他診斷（如DIC、ITP）",
            "3. CEA升高需考慮惡性腫瘤可能",
            "4. 多發血栓需考慮易栓症（thrombophilia）",
            "5. 甲狀腺/腎上腺結節需進一步評估"
        ]
        
        for point in expected_points:
            if any(keyword in gpt_response for keyword in point.split()[:3]):
                print(f"  ✅ {point}")
